{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Ritgard.Console",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/console/bin/Debug/net9.0/Ritgard.Console.dll",
            "preLaunchTask": "build",
            "args": [
                "adjust-layout",
                "${workspaceFolder}/console/lume.csv",
                "${workspaceFolder}/console/topics_lume.csv"
            ]
        },
        {
            "name": "test.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/data-processing/test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/data-processing",
            "justMyCode": true
        }
    ]
}
