{
  "profiles": {
    "(repo: dotvvm)": {
      "commandName": "Project",
      "commandLineArgs": "repo riganti/dotvvm --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: lume)": {
      "commandName": "Project",
      "commandLineArgs": "repo lumeland/lume --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: jetuml)": {
      "commandName": "Project",
      "commandLineArgs": "repo prmr/jetuml --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: gwf)": {
      "commandName": "Project",
      "commandLineArgs": "repo git-for-windows/git --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: stb)": {
      "commandName": "Project",
      "commandLineArgs": "repo nothings/stb --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: d3)": {
      "commandName": "Project",
      "commandLineArgs": "repo d3/d3 --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: axios)": {
      "commandName": "Project",
      "commandLineArgs": "repo axios/axios --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: tailwindcss)": {
      "commandName": "Project",
      "commandLineArgs": "repo tailwindlabs/tailwindcss --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(repo: markitdown)": {
      "commandName": "Project",
      "commandLineArgs": "repo microsoft/markitdown --scope All",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(terrain: lume)": {
      "commandName": "Project",
      "commandLineArgs": "terrain ../datasets/lume.json ../datasets/lume-positions.json",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(terrain: jetuml)": {
      "commandName": "Project",
      "commandLineArgs": "terrain ../datasets/jetuml.json ../datasets/jetuml-positions.json",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "(terrain: dotvvm)": {
      "commandName": "Project",
      "commandLineArgs": "terrain ../datasets/dotvvm.json ../datasets/dotvvm-positions.json --step-length-multiplier 7",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    }
  }
}